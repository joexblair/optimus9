//@version=6
strategy('BBSTR_ENGINE',
     overlay                 = false,
     precision               = 1,
     initial_capital         = 500,
     currency                = currency.USDT,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 33300,
     pyramiding              = 10,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.205,
     slippage                = 3,
     calc_on_order_fills     = true,
     process_orders_on_close = true,
     margin_long             = 1.82,
     margin_short            = 1.82,
     max_labels_count        = 500,
     max_lines_count         = 500)


// Generated from optimus9 inspector
// tc_pk=4 (gca5m)
// 1218 signals
// Generated at 2026-05-17 21:53:48 UTC

// ─── UI inputs ──────────────────────────────────────────
sl_pct      = input.float(0.7, "Stop loss %",   minval=0.1, step=0.04)
tp_pct      = input.float(1.1, "Take profit %", minval=0.1, step=0.04)
exit_method = input.string("current tp value", "Exit method",
                           options=["current tp value", "no tp"])

_sl_mult = sl_pct / 100.0
_tp_mult = tp_pct / 100.0

