// ─── Sequential cursor matcher ──────────────────────────
// Signals are time-ordered. Advance cursor past any timestamp
// the current bar has already passed (handles TV data gaps).
var int next_sig_idx = 0
bool _sig_long  = false
bool _sig_short = false

while next_sig_idx < array.size(SIG_TS) and array.get(SIG_TS, next_sig_idx) < time
    next_sig_idx := next_sig_idx + 1

if next_sig_idx < array.size(SIG_TS) and array.get(SIG_TS, next_sig_idx) == time
    int _dir = array.get(SIG_DIR, next_sig_idx)
    if _dir == 1
        _sig_long := true
    else
        _sig_short := true
    next_sig_idx := next_sig_idx + 1

bool _can_long  = _sig_long
bool _can_short = _sig_short

// ─── Exit + Entry block ─────────────────────────────────
bool   use_fixed_tp = exit_method == "current tp value"
float  tp_long      = use_fixed_tp and strategy.position_size > 0 ? strategy.position_avg_price * (1 + _tp_mult) : na
float  tp_short     = use_fixed_tp and strategy.position_size < 0 ? strategy.position_avg_price * (1 - _tp_mult) : na

// SL always active. TP is conditional
if strategy.position_size > 0
    strategy.exit('XL', from_entry='L',
         stop  = strategy.position_avg_price * (1 - _sl_mult),
         limit = tp_long)
if strategy.position_size < 0
    strategy.exit('XS', from_entry='S',
         stop  = strategy.position_avg_price * (1 + _sl_mult),
         limit = tp_short)

// Entries
if _sig_long and _can_long
    strategy.entry('L', strategy.long)
if _sig_short and _can_short
    strategy.entry('S', strategy.short)
