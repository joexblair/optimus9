[Unit]
Description=Optimus9 kline auditor (independent REST audit of kline_collection)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=joe
WorkingDirectory=/home/joe/thecodes
ExecStart=/usr/bin/python3 run.py kline_audit
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
