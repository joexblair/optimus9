# fake-API container — the mock Bybit v5 exchange (live order-book fills)
FROM python:3.12-slim
WORKDIR /app
COPY deploy/o9live/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY . /app
ENV PYTHONPATH=/app
EXPOSE 8098
CMD ["uvicorn", "services.fakeapi.app:app", "--host", "0.0.0.0", "--port", "8098"]
